{
  "manifest_version": 3,
  "name": "SF Downloader Integration",
  "version": "0.2.6",
  "description": "Integra downloads do Firefox ao SF Downloader.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "downloads",
    "cookies",
    "alarms",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:17831/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "SF Downloader",
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "integration@sfdownloader.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent",
          "websiteActivity"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
